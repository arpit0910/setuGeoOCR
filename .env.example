# ── Tesseract ──────────────────────────────────────────────────────────────
# Path to the Tesseract binary.
# Windows default after installer: C:\Program Files\Tesseract-OCR\tesseract.exe
# Linux/Mac:                        /usr/bin/tesseract
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# OCR language(s). Add 'hin' for Hindi (requires tessdata-fast or tessdata pack).
# e.g. eng+hin for bilingual Aadhaar cards
TESSERACT_LANG=eng

# Tesseract page-segmentation mode config
TESSERACT_CONFIG=--oem 3 --psm 6

# ── Service ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8001

# ── Upload limits ──────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
