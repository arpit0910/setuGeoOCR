# --- PASSENGER CONFIGURATION ---
# DO NOT REMOVE. CLOUDLINUX PASSENGER CONFIGURATION BEGIN
# IMPORTANT: If you move this to a new CPanel account, update the paths below.
PassengerAppRoot "/home/outgglmv/setuGeoOCR"
PassengerBaseURI "/"
PassengerPython "/home/outgglmv/virtualenv/setuGeoOCR/3.11/bin/python"
# DO NOT REMOVE. CLOUDLINUX PASSENGER CONFIGURATION END

# --- SERVER OPTIMIZATIONS ---
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # 1. Handle Canonical Host & Force HTTPS
    # Ensure all traffic hits https://api.geosetu.com
    RewriteCond %{HTTP_HOST} !^api\.geosetu\.com$ [NC]
    RewriteRule ^ https://api.geosetu.com%{REQUEST_URI} [R=301,L]
    
    RewriteCond %{HTTPS} !=on
    RewriteRule ^ https://api.geosetu.com%{REQUEST_URI} [R=301,L]

    # 2. Prevent Apache from blocking the WSGI entry point
    # We allow .py files to be accessed by the Passenger engine internally
    RewriteRule (^|/)(\.env|\.git|Dockerfile|requirements\.txt)$ - [F,L,NC]
</IfModule>

# --- SECURITY HEADERS ---
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set Referrer-Policy "no-referrer-when-downgrade"
</IfModule>

# Match the application upload limit (10MB for OCR images)
LimitRequestBody 10485760