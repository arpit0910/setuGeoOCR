# --- PASSENGER CONFIGURATION ---
PassengerEnabled on
PassengerAppType wsgi
PassengerStartupFile passenger_wsgi.py
PassengerAppRoot "/home/outgglmv/setuGeoOCR"
PassengerBaseURI "/"
PassengerPython "/home/outgglmv/virtualenv/setuGeoOCR/3.11/bin/python"
PassengerStartTimeout 300
PassengerMinInstances 1

# --- SERVER OPTIMIZATIONS ---
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # 1. Handle Canonical Host & Force HTTPS
    RewriteCond %{HTTP_HOST} !^api\.setugeo\.com$ [NC]
    RewriteCond %{HTTP_HOST} !^localhost$ [NC]
    RewriteCond %{HTTP_HOST} !^127\.0\.0\.1$ [NC]
    RewriteRule ^ https://api.setugeo.com%{REQUEST_URI} [R=301,L]
    
    RewriteCond %{HTTPS} !=on
    RewriteCond %{HTTP_HOST} !^localhost$ [NC]
    RewriteCond %{HTTP_HOST} !^127\.0\.0\.1$ [NC]
    RewriteRule ^ https://api.setugeo.com%{REQUEST_URI} [R=301,L]

    # 2. Prevent direct access to sensitive files
    RewriteRule (^|/)(\.env|\.git|requirements\.txt|passenger_debug\.log|error_debug\.log)$ - [F,L,NC]
</IfModule>

# --- SECURITY HEADERS ---
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>