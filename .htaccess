# Production Apache configuration for SetuGeo OCR.
# Requires mod_rewrite, mod_proxy, mod_proxy_http, and mod_headers.

Options -Indexes
DirectoryIndex disabled

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set Referrer-Policy "no-referrer"
</IfModule>

# Match the application upload limit.
LimitRequestBody 10485760

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Canonical production host.
    RewriteCond %{HTTP_HOST} !^ocr\.setugeo\.com$ [NC]
    RewriteRule ^ https://ocr.setugeo.com%{REQUEST_URI} [R=301,L]

    # Block direct access to sensitive project and runtime files.
    RewriteRule (^|/)(\.env|\.env\..*|\.git|\.dockerignore|Dockerfile|docker-compose\.yml|requirements\.txt|ocr_service\.log)$ - [F,L,NC]
    RewriteRule ^(uploads|scratch|__pycache__|\.vscode)(/|$) - [F,L,NC]
    RewriteRule \.(py|pyc|pyo|log|ini|bak|sql|sqlite|db)$ - [F,L,NC]

    # Force HTTPS on the production host when Apache terminates TLS directly.
    RewriteCond %{HTTPS} !=on
    RewriteRule ^ https://ocr.setugeo.com%{REQUEST_URI} [R=301,L]

    # FOR CPANEL / PASSENGER HOSTING:
    # Comment out the proxy rules below because Passenger will handle the routing directly.
    # If you are NOT using Passenger and running uvicorn in the background, uncomment these.
    # RewriteRule ^(.*)$ http://127.0.0.1:8001/$1 [P,L,QSA]
</IfModule>
